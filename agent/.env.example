# CONFIGURACIÓN DE RESPALDO WASABI S3 (DBP AGENT)

# URL del bucket: s3:s3.wasabisys.com/tu-bucket-nombre
RESTIC_REPOSITORY=s3:s3.wasabisys.com/dbp-backups-hwperu

# Credenciales de Wasabi (Seccion Access Keys del Panel)
AWS_ACCESS_KEY_ID=TU_ACCESS_KEY_AQUI
AWS_SECRET_ACCESS_KEY=TU_SECRET_KEY_AQUI

# Contraseña de Encriptación (Restic necesita esto para cifrar tus datos en la nube)
RESTIC_PASSWORD=TU_SUPER_PASSWORD_DBP_123

# --- IDENTIFICACIÓN (MANUAL O AUTOMÁTICA) ---

# ID del Agente (Dejar VACÍO para usar el HOSTNAME del servidor automáticamente)
DBP_AGENT_ID=

# Token de Seguridad del Cliente (OBLIGATORIO) 
# Este token vincula el VPS con la cuenta de WHMCS. 
# Si usas el script de instalación automática (install.sh), este campo ya vendrá lleno.
DBP_API_TOKEN=dbp_tenant_TU_TOKEN_AQUI

# Endpoint de la API Central
DBP_API_ENDPOINT=https://api.hwperu.com

