# ==========================================
# Docker Backup Pro - Central API (.env)
# ==========================================

# 1. Base de Datos (Postgres)
DB_HOST=localhost
DB_PORT=5432
DB_USER=dbpuser
DB_PASS=IngresaUnPasswordComplejoAca
DB_NAME=dbp_data

# 2. Seguridad & Auth
PORT=8089
JWT_SECRET=tu_llave_maestra_jwt_secreta
API_ADMIN_KEY=dbp_admin_hwperu_master_2024_secure_v1
MASTER_ADMIN_TOKEN=dbp_admin_hwperu_master_2024_secure_v1
DBP_ENCRYPTION_KEY=307e8062b284d4bb028833284c9745dd549f7d081c83e55f3887b99ef1cc2c73

# Entorno (gin.debug o gin.release)
GIN_MODE=release

# 3. Observabilidad & Cache (SOC2)
# El puerto 6390 corresponde al mapeo en docker-compose.monitoring.yml
REDIS_URL=localhost:6390
RATE_LIMIT_REDIS_URL=localhost:6390
PROMETHEUS_ENABLED=true
LOG_RETENTION_DAYS=90

# 4. Proveedor de Continuidad (Virtualizor DR)
DR_PROVIDER=virtualizor
VIRTUALIZOR_URL=https://tu-panel-virtualizor.com:4085
VIRTUALIZOR_KEY=TU_API_KEY
VIRTUALIZOR_PASS=TU_API_PASS
VIRTUALIZOR_BRIDGE=viifbr0

# 5. Wasabi S3 Config
WASABI_ACCESS_KEY=TU_ACCESS_KEY
WASABI_SECRET_KEY=TU_SECRET_KEY
WASABI_REGION=us-east-1
WASABI_BUCKET=dbp-backups-hwperu
RESTIC_REPOSITORY=s3:s3.wasabisys.com/dbp-backups-hwperu
RESTIC_PASSWORD=password_para_cifrado_zero_knowledge

# 6. Alertas Externas
# N8N_WEBHOOK=https://n8n.tuempresa.com/webhook/alerts
