# ------------------------------------------
# 1. API Central & Base de Datos Postgres
# (Leídas por docker-compose.yml)
# ------------------------------------------
DB_USER=dbpuser
DB_PASS=IngresaUnPasswordComplejoAca
DB_NAME=dbp_data
API_PORT=8089
JWT_SECRET=tu_llave_maestra_jwt_secreta

# ------------------------------------------
# 2. UI Dashboard
# (Usado si despliegas localmente o se pega en la config de Vercel)
# ------------------------------------------
NEXT_PUBLIC_API_URL=https://api.tuempresa.com/v1
